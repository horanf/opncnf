{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "minimax-cn-coding-plan/MiniMax-M2.5",
  "default_agent": "router",
  "agent": {
    "plan": {
      "description": "Plan, analyze, and orchestrate work without making code changes.",
      "mode": "all",
      "model": "kimi-for-coding/k2p5",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    }
  }
}
